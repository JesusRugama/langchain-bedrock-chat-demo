AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.amazon.nova-lite-v1:0

# Chat history window size (number of messages to keep)
# Even numbers will be incremented by 1 to ensure starting with user message
# 10 -> 11 messages = 5.5 turns (6 user + 5 assistant)
CHAT_HISTORY_WINDOW=10

# AWS SSO Credentials (recommended)
# Run `aws sso login --profile <your-profile>` to authenticate
# The SDK will automatically use SSO credentials from ~/.aws/config
# No need to set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here
